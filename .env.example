APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Đường dẫn tới file model đã huấn luyện
MODEL_PATH=ml/model.pt

# CORS - danh sách origin được phép (frontend)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Mapping TARGET_COLS của model → plant_signal trong API
# Xem TARGET_COLS trong notebook training của bạn (Cell 1 hoặc 2)
PLANT_SIGNAL_A_COL=attr_3
PLANT_SIGNAL_B_COL=attr_6

# Giá trị tối đa model có thể trả về (để normalize về 0–99)
# Nếu model trả về 0–99 thì để nguyên = 99
PLANT_SIGNAL_MAX=99
